# Mesh file
mesh file = mesh/rect.msh

# Output directory prefix
output prefix = adr_transient
output type = pvd

# Set flow physics type
transport physics type = transient scalar transport

# Physical properties
diffusivity = 1e-2
flow velocity = (1, 0)
reaction = 0.0

# Time dependent variables
time step size = 1e-2
time span = 1
save every = 5
initial condition = (inputs/c.bp, c)

# SUPG stabilization
add supg = true

# Boundary conditions
one = 1.0
zero = 0.0
BC1 = (1, fixed value, one)

