# Mesh file
mesh file = mesh/rect.msh

# Output directory prefix
output prefix = adr_steady 
output type = pvd

# Set flow physics type
transport physics type = steady scalar transport

# Physical properties
diffusivity = 1
flow velocity = (0, 0)
reaction = 0.0

# SUPG stabilization
add supg = true

# Boundary conditions
gc_inlet = (1, 0)
a = 1
b = 0
BC1 = (1, gradient value, gc_inlet)
BC2 = (3, fixed value, b)