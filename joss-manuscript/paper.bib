	keywords = {Finite elements, Mathematical software, Scientific computing, Software design},
	pages = {407--422},
	file = {ScienceDirect Full Text PDF:C\:\\Users\\Nick\\Zotero\\storage\\TXJ85AMK\\Arndt et al. - 2021 - The deal.II finite element library Design, features, and insights.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\Nick\\Zotero\\storage\\J8A924BH\\S0898122120300894.html:text/html},
